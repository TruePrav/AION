# AION — Required Environment Variables
# Copy this to .env.local and fill in your values

# ── Backend URL ──
# AION_BACKEND_URL is server-side only (never exposed to browser).
# Use this for BOTH local dev with a VPS and production (Vercel).
# AION_BACKEND_URL=http://your-vps-ip:5001

# ── Local development only ──
# NEXT_PUBLIC_API_URL is ONLY for local dev when backend runs on localhost.
# ⚠️ NEVER set this to a remote VPS IP — the NEXT_PUBLIC_ prefix exposes it in the browser!
# NEXT_PUBLIC_API_URL=http://localhost:5001

# API key for authenticated mutations (trade execution, settings changes).
# Server-side only — proxied through /api/admin/[...path].
# Generate a strong random key and set the SAME key on your backend.
# Without this, the dashboard is read-only (safe for public deployment).
AION_API_KEY=

# Enable write operations (trade, settings) from the dashboard.
# ADMIN_ALLOW_MUTATIONS=1

# Anthropic API key for "Ask AION" AI chat feature (server-side only, never exposed to browser)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Microsoft Clarity — free heatmaps & session recordings
# Sign up at https://clarity.microsoft.com and create a project to get your ID
# NEXT_PUBLIC_CLARITY_ID=

# Nansen API key — only needed on the backend, NOT here.
# Configure NANSEN_API_KEY on your backend environment only.
