# Oracle v3 — Required Environment Variables
# Copy this to .env.local and fill in your values

# API base URL — your Oracle backend
NEXT_PUBLIC_API_URL=http://localhost:5001

# API key for authenticated mutations (trade execution, settings changes).
# Server-side only — proxied through /api/admin/[...path].
# Generate a strong random key and set the SAME key on your backend.
# Without this, the dashboard is read-only (safe for public deployment).
ORACLE_API_KEY=

# Anthropic API key for "Ask AION" AI chat feature (server-side only, never exposed to browser)
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# IMPORTANT: Your trading wallet private key should ONLY exist on the backend server.
# It must NEVER be set in this frontend .env file.
# Configure ORACLE_WALLET_PRIVATE_KEY on your backend environment only.
