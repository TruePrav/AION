# Oracle v3 — Required Environment Variables
# Copy this to .env.local and fill in your values

# API base URL — your Oracle backend
NEXT_PUBLIC_API_URL=http://localhost:5001

# API key for authenticated actions (trade execution, position close, settings changes)
# Generate a strong random key and set the SAME key on your backend to validate requests.
# Without this key, trade execution and settings changes will be blocked.
NEXT_PUBLIC_ORACLE_API_KEY=

# IMPORTANT: Your trading wallet private key should ONLY exist on the backend server.
# It must NEVER be set in this frontend .env file.
# Configure ORACLE_WALLET_PRIVATE_KEY on your backend environment only.
